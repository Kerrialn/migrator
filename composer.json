{
    "name": "kerrialn/migrator",
    "require": {
        "php": "^8.2",
        "symfony/console": "^7.1",
        "symfony/process": "^7.1",
        "phpstan/phpstan": "^2.1",
        "kerrialn/composer-json-parser": "v2.0",
        "symfony/finder": "^7.1",
        "nesbot/carbon": "^3.8",
        "symfony/filesystem": "^7.2",
        "nette/utils": "^4.0",
        "doctrine/dbal": "^4.2",
        "graphp/graphviz": "^0.2.2"
    },
    "bin": [
        "bin/migrator"
    ],
    "require-dev": {
        "symplify/easy-coding-standard": "^12.3",
        "rector/rector": "^2",
        "phpunit/phpunit": "^12",
        "phpmetrics/phpmetrics": "^0.0.2"
    },
    "autoload": {
        "psr-4": {
            "KerrialNewham\\Migrator\\": "src/"
        },
        "exclude-from-classmap": [
            "/vendor/phploc/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "tests/"
        }
    },
    "scripts": {
        "ps": "vendor/bin/phpstan --memory-limit=-1",
        "rector": "vendor/bin/rector",
        "check-cs": "vendor/bin/ecs",
        "fix-cs": "vendor/bin/ecs --fix",
        "unit-test": "vendor/bin/phpunit tests --testdox --dont-report-useless-tests --colors"
    }
}
